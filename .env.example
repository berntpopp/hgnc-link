# hgnc-link configuration (copy to .env). All vars use the HGNC_LINK_ prefix.
# Nested config uses a double underscore, e.g. HGNC_LINK_DATA__DB_FILENAME.

# --- Server ---
# HGNC_LINK_HOST=127.0.0.1
# HGNC_LINK_PORT=8000
# HGNC_LINK_TRANSPORT=unified           # unified | http | stdio
# JSON lists. Add the exact public reverse-proxy hostname in production.
# HGNC_LINK_ALLOWED_HOSTS=["localhost","127.0.0.1","::1"]
# HGNC_LINK_ALLOWED_ORIGINS=[]
# Browser deployments must also set HGNC_LINK_CORS_ORIGINS to the same origins;
# CORS response headers and request Origin validation are separate boundaries.
# HGNC_LINK_LOG_LEVEL=INFO
# HGNC_LINK_LOG_FORMAT=console          # console | json

# --- Local data store (bulk downloads -> SQLite index) ---
# HGNC_LINK_DATA__DATA_DIR=./data
# HGNC_LINK_DATA__AUTO_BOOTSTRAP=true   # build the DB on first start if absent
# HGNC_LINK_DATA__REFRESH_ENABLED=false # cron owns refresh by default
# HGNC_LINK_DATA__REFRESH_INTERVAL_HOURS=24

# --- Live REST client (rest.genenames.org) — see docs/configuration.md ---
# Reserved, NOT wired: no service method calls the REST client today, so enabling
# this only constructs an unused client. The local index is the sole query path.
# HGNC_LINK_API__CONTACT_EMAIL=you@example.org
# HGNC_LINK_API__TIMEOUT=30
# HGNC_LINK_API__ENABLE_LIVE_FALLBACK=false
